@model RegistrationApp.Models.User

@{
    ViewData["Title"] = "Đăng ký thành công";
}

<div class="register-page d-flex align-items-center justify-content-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card register-card text-center">
                    <div class="card-body p-5">
                        <div class="mb-4">
                            <span class="badge bg-success rounded-pill py-2 px-3">Thành công</span>
                        </div>
                        <h2 class="mb-3">Đăng ký thành công!</h2>
                        <p class="text-muted mb-3">Tài khoản <strong>@Model.Username</strong> đã được tạo.</p>
                        <p class="mb-4">Email đăng ký: <strong>@Model.Email</strong></p>
                        <a asp-action="Index" class="btn btn-primary btn-lg">Đăng ký tài khoản khác</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
